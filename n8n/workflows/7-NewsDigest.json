        "query": "SELECT ni.id, ni.title, ni.summary, ni.published_at, ni.url,\n       ns.name as source_name, ns.category\nFROM news_items ni\nJOIN news_sources ns ON ns.id = ni.source_id\nWHERE ni.ingested_to_qdrant = FALSE\nAND ni.summary IS NOT NULL\nAND ni.summary != ''\nORDER BY ni.published_at DESC\nLIMIT 100;",
