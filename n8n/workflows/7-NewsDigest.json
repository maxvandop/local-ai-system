    {
      "parameters": {
        "jsCode": "\nconst sourceId   = $('Loop Over Sources').item.json.id;\nconst sourceName = $('Loop Over Sources').item.json.name;\nconst category   = $('Loop Over Sources').item.json.category;\nconst rawXml     = $input.first().json.data || '';\n\nif (!rawXml || rawXml.trim().length === 0) {\n  return [{ json: { articles: [], source_id: sourceId, skipped: true } }];\n}\n\n// Simple RSS item parser — handles most standard RSS 2.0 and Atom feeds\nconst items = [];\nconst itemRegex = /<item[^>]*>([\\s\\S]*?)<\\/item>|<entry[^>]*>([\\s\\S]*?)<\\/entry>/gi;\nlet match;\n\nwhile ((match = itemRegex.exec(rawXml)) !== null) {\n  const block = match[1] || match[2];\n\n  const getTag = (tag) => {\n    const m = block.match(new RegExp(`<${tag}[^>]*><!\\\\[CDATA\\\\[([\\\\s\\\\S]*?)\\\\]\\\\]></${tag}>|<${tag}[^>]*>([\\\\s\\\\S]*?)</${tag}>`, 'i'));\n    return m ? (m[1] || m[2] || '').trim() : '';\n  };\n\n  const title     = getTag('title').replace(/<[^>]+>/g, '');\n  const link      = getTag('link') || getTag('guid');\n  const pubDate   = getTag('pubDate') || getTag('published') || getTag('updated');\n  const desc      = getTag('description') || getTag('summary') || getTag('content');\n  const cleanDesc = desc.replace(/<[^>]+>/g, '').replace(/\\s+/g, ' ').trim().slice(0, 500);\n\n  if (title && title.length > 0) {\n    items.push({\n      source_id:    sourceId,\n      source_name:  sourceName,\n      category,\n      title:        title.slice(0, 500),\n      summary:      cleanDesc,\n      url:          link.slice(0, 1000),\n      published_at: pubDate ? new Date(pubDate).toISOString() : new Date().toISOString()\n    });\n  }\n\n  if (items.length >= 20) break; // max 20 items per source\n}\n\nreturn items.length > 0\n  ? items.map(a => ({ json: a }))\n  : [{ json: { articles: [], source_id: sourceId, skipped: true } }];\n"
      },
