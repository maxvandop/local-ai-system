      "parameters": {
        "jsCode": "\nconst items = $input.all();\n\nconst ids = items.map(i => i.json.id);\nconst text = items.map(i => {\n  const pub = new Date(i.json.published_at).toLocaleDateString('en-GB');\n  return `[${pub}] ${i.json.source_name} (${i.json.category}): ${i.json.title}. ${i.json.summary || ''}`;\n}).join('\\n\\n');\n\nreturn [{ json: { text, ids } }];\n"
