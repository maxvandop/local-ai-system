        "jsonExample": "  {\n    \"InputType\": \"voice\",\n    \"RequestInput\": {\n      \"input\": \"Test\"\n    },\n    \"ChannelInformation\": {\n      \"ChannelID\": 8497733638,\n      \"MessageID\": 730\n    }\n  }\n"
      },
