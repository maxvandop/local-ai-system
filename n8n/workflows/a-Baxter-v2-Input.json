    {
      "parameters": {
        "jsCode": "const inputType = $('InputType').first().json.inputType;\nconst input = $('InputContent').first().json.input;\n\nlet channelId = null;\nlet messageId = null;\n\ntry {\n  channelId = $('Telegram Trigger').first().json.message.chat.id;\n  messageId = $('Telegram Trigger').first().json.message.message_id;\n} catch(e) {}\n\nconst taskName = input.length > 80 ? input.slice(0, 80) + '...' : input;\n\nreturn [{\n  json: {\n    id: null,\n    name: taskName,\n    type: 'orchestrator',\n    status: 'pending',\n    agent: 'baxter-orchestrator',\n    dependsOn: [],\n    requiresApproval: false,\n    prompts: {\n      user: input,\n      core: 'core-prompt-v1',\n      context: ''\n    },\n    contextFile: null,\n    projectId: null,\n    parentTaskId: null,\n    previousTaskId: null,\n    nextTaskId: null,\n    reminders: [],\n    subtasks: [],\n    result: null,\n    response: null,\n    metadata: {\n      inputType: inputType,\n      telegram: {\n        channelId: channelId,\n        messageId: messageId\n      }\n    }\n  }\n}];"
      },
