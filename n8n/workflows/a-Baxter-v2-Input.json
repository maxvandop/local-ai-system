    {
      "parameters": {
        "jsCode": "let inputType = \"\";\n\ntry { $('Chat_Input').first(); inputType = \"chat\"; } catch(e) {}\ntry { if (!inputType) { $('Text_Input').first(); inputType = \"text\"; } } catch(e) {}\ntry { if (!inputType) { $('Audio_Input').first(); inputType = \"voice\"; } } catch(e) {}\n\nreturn { inputType };"
