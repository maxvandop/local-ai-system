    {
      "parameters": {
        "jsCode": "const cleanOutput = () => {\n    const input = $('SetVars').first().json.AgentOutput?.response;\n\n    if (!input || typeof input !== 'string') {\n        return [{ json: { output: 'Error: Input data not found.' } }];\n    }\n\n    // Remove <think> blocks\n    let output = input.replace(/<\\s*\\/?\\s*think\\s*[^>]*>.*?<\\s*\\/?\\s*think\\s*[^>]*>/gis, '');\n\n    // Split on newlines and filter out reasoning lines\n    const reasoningPatterns = [\n        /^okay[,\\s]/i,\n        /^let me\\s/i,\n        /^i need to\\s/i,\n        /^i should\\s/i,\n        /^since there/i,\n        /^the user/i,\n        /^therefore/i,\n        /^so i'll/i,\n        /^alright/i,\n        /^make sure/i,\n        /^i'll make/i,\n        /^first[,\\s]/i,\n    ];\n\n    const lines = output.split('\\n').map(l => l.trim()).filter(Boolean);\n    const responseLines = lines.filter(line => \n        !reasoningPatterns.some(pattern => pattern.test(line))\n    );\n\n    output = responseLines.length > 0 ? responseLines.join(' ') : lines[lines.length - 1];\n\n    // Remove HTML, markdown, emojis, quotes\n    output = output.replace(/<[^>]*>/g, '');\n    output = output.replace(/^#{1,6}\\s|^\\s*>\\s|^\\s*[-*]{3,}\\s*$/gm, '');\n    output = output.replace(/(\\*\\*|__|\\*|_|`|\\[.*?\\]\\(.*?\\))/g, '');\n    output = output.replace(/[\\p{Emoji_Presentation}\\p{Extended_Pictographic}]/gu, '');\n    output = output.replace(/\"/g, '');\n    output = output.replace(/[\\n\\s]+/g, ' ').trim();\n\n    return [{ json: { output } }];\n};\nreturn cleanOutput();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
