        "jsCode": "let output = $('SetVars').first().json.AgentOutput.response || '';\n\n// Remove <think> blocks — closed and unclosed\noutput = output.replace(/<think>[\\s\\S]*?<\\/think>/gi, '');\noutput = output.replace(/<think>[\\s\\S]*/gi, '');\n\n// Clean up excessive whitespace but preserve newlines for readability\noutput = output.replace(/\\n{3,}/g, '\\n\\n').trim();\n\nreturn { output };"
